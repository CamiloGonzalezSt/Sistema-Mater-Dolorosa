# ===== Django =====
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-render-domain.onrender.com

# ===== Base de datos =====
# SQLite se usa en producción (Render). Cambiar a False solo si usas MySQL en desarrollo.
USE_SQLITE=True

# (Descomentar solo si USE_SQLITE=False y quieres MySQL local)
# DB_NAME=mater_dolorosa
# DB_USER=root
# DB_PASSWORD=mysql123
# DB_HOST=127.0.0.1
# DB_PORT=3306

# ===== 2FA en admin =====
ADMIN_2FA=False

# ===== Email (opcional, para notificaciones en producción) =====
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-app-password
EMAIL_USE_TLS=True
ADMIN_EMAILS=admin1@example.com,admin2@example.com
